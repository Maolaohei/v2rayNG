<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="@dimen/padding_spacing_dp8">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/padding_spacing_dp16"
        android:paddingEnd="@dimen/padding_spacing_dp16"
        android:paddingBottom="@dimen/padding_spacing_dp4"
        android:text="@string/home_more_tools"
        android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_home_list_card"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/item_per_app"
            style="@style/HomeMoreItem">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/per_app_proxy_settings"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_chevron_right_24dp"
                app:tint="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/item_assets"
            style="@style/HomeMoreItem">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_user_asset_setting"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_chevron_right_24dp"
                app:tint="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/item_logcat"
            style="@style/HomeMoreItem">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_logcat"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_chevron_right_24dp"
                app:tint="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/item_backup"
            style="@style/HomeMoreItem">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_configuration_backup_restore"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_chevron_right_24dp"
                app:tint="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/item_update"
            style="@style/HomeMoreItem">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/update_check_for_update"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_chevron_right_24dp"
                app:tint="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/item_about"
            style="@style/HomeMoreItem">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_about"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_chevron_right_24dp"
                app:tint="?attr/colorOnSurfaceVariant" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/padding_spacing_dp16"
        android:paddingTop="@dimen/padding_spacing_dp16"
        android:paddingEnd="@dimen/padding_spacing_dp16"
        android:paddingBottom="@dimen/padding_spacing_dp4"
        android:text="@string/title_settings"
        android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/settings_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>