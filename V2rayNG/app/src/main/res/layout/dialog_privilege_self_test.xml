<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/padding_spacing_dp16"
        android:paddingEnd="@dimen/padding_spacing_dp16"
        android:paddingTop="@dimen/padding_spacing_dp8"
        android:paddingBottom="@dimen/padding_spacing_dp8">

        <LinearLayout
            android:id="@+id/status_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_spacing_dp16"
            android:background="@drawable/bg_privilege_status_partial">

            <TextView
                android:id="@+id/tv_status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/summary_pref_privilege_self_test_status_label"
                android:textAllCaps="true"
                android:textSize="11sp"
                android:letterSpacing="0.06"
                android:textColor="?android:attr/textColorSecondary" />

            <TextView
                android:id="@+id/tv_status_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp4"
                android:textStyle="bold"
                android:textSize="15sp"
                android:lineSpacingExtra="2dp"
                android:textColor="?android:attr/textColorPrimary"
                tools:text="状态：应用侧隐藏正常 — 仍可见原生网卡名（预期）" />

            <TextView
                android:id="@+id/tv_status_headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp4"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"
                android:textColor="?android:attr/textColorSecondary"
                tools:text="应用侧检测看起来干净；内核网卡名仍可见" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp16"
            android:text="@string/summary_pref_privilege_self_test_section_java_title"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorPrimary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:orientation="vertical"
            android:background="@drawable/bg_privilege_section"
            android:padding="@dimen/padding_spacing_dp12">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/summary_pref_privilege_self_test_row_result"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_java_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/padding_spacing_dp8"
                    android:paddingEnd="@dimen/padding_spacing_dp8"
                    android:paddingTop="@dimen/padding_spacing_dp2"
                    android:paddingBottom="@dimen/padding_spacing_dp2"
                    android:background="@drawable/bg_privilege_pill_ok"
                    android:textColor="@color/color_privilege_ok_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="干净" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp8"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/summary_pref_privilege_self_test_row_hits"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_java_hits"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.4"
                    android:gravity="end"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="13sp"
                    tools:text="未检测到" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp8"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/summary_pref_privilege_self_test_row_ifaces"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_java_ifaces"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.4"
                    android:gravity="end"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="13sp"
                    tools:text="未检测到" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp16"
            android:text="@string/summary_pref_privilege_self_test_section_native_title"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorPrimary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:orientation="vertical"
            android:background="@drawable/bg_privilege_section"
            android:padding="@dimen/padding_spacing_dp12">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/summary_pref_privilege_self_test_row_result"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_native_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/padding_spacing_dp8"
                    android:paddingEnd="@dimen/padding_spacing_dp8"
                    android:paddingTop="@dimen/padding_spacing_dp2"
                    android:paddingBottom="@dimen/padding_spacing_dp2"
                    android:background="@drawable/bg_privilege_pill_warn"
                    android:textColor="@color/color_privilege_warn_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="可见 tun0" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_native_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp8"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"
                tools:text="改名已停用，不等于隐藏失败" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp16"
            android:text="@string/summary_pref_privilege_self_test_section_conditions_title"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorPrimary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:orientation="vertical"
            android:background="@drawable/bg_privilege_section"
            android:padding="@dimen/padding_spacing_dp12">

            <TextView
                android:id="@+id/tv_setup_module"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorPrimary"
                tools:text="模块：已激活" />

            <TextView
                android:id="@+id/tv_setup_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp4"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorPrimary"
                tools:text="同步：是" />

            <TextView
                android:id="@+id/tv_setup_targets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp4"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorPrimary"
                tools:text="目标：19 · 本应用在名单" />

            <TextView
                android:id="@+id/tv_setup_vpn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp4"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorPrimary"
                tools:text="VPN：运行中 · 疑似在隧道内" />

            <TextView
                android:id="@+id/tv_setup_ports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp4"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorPrimary"
                tools:text="回环拦截：已开启" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp16"
            android:text="@string/summary_pref_privilege_self_test_section_note_title"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorPrimary" />

        <TextView
            android:id="@+id/tv_meaning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:background="@drawable/bg_privilege_section"
            android:padding="@dimen/padding_spacing_dp12"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp"
            android:textColor="?android:attr/textColorSecondary"
            tools:text="含义：Java API 隐藏在工作。" />
    </LinearLayout>
</ScrollView>
